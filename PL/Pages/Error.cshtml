@page
@model ErrorModel
@{
    ViewData["Title"] = "Lỗi";
}

<h1 class="text-danger">Đã xảy ra lỗi.</h1>
<h2 class="text-danger">Yêu cầu của bạn không thể xử lý. Vui lòng thử lại sau.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Chế độ phát triển</h3>
<p>
    Chuyển sang môi trường <strong>Development</strong> để hiển thị thông tin chi tiết về lỗi đã xảy ra.
</p>
<p>
    <strong>Không nên bật môi trường Development cho ứng dụng đã triển khai.</strong>
    Điều này có thể hiển thị thông tin nhạy cảm từ ngoại lệ cho người dùng cuối.
</p>
