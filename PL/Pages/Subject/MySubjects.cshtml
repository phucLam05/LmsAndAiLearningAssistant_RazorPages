@page
@model PL.Pages.Subject.MySubjectsModel
@{
    ViewData["Title"] = "Môn học của tôi";
}

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6 select-none">
    <div>
        <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-[10px] font-mono font-bold tracking-tight uppercase">Giảng viên</span>
        <h1 class="font-headline-lg text-headline-lg md:font-display-lg md:text-display-lg font-bold text-on-surface mt-2 tracking-tight">Môn học của tôi</h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Danh sách các môn học bạn được phân công phụ trách. Upload tài liệu để AI có thể hỗ trợ sinh viên.</p>
    </div>
    <span class="text-xs text-on-surface-variant">@Model.Page.TotalCount môn học</span>
</div>

<form method="get" class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-3 mb-6 shadow-sm select-none">
    <input type="hidden" name="pageIndex" value="1" />
    <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-outline text-[20px]">search</span>
        </div>
        <input type="text" name="search" value="@Model.Search" class="w-full bg-surface border border-outline-variant/50 text-on-surface rounded-xl pl-10 pr-10 py-2.5 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder:text-outline/50 text-sm" placeholder="Tìm tên môn học hoặc mã..." />
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <a href="/Subject/MySubjects" class="absolute inset-y-0 right-0 pr-3 flex items-center text-outline hover:text-on-surface">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </a>
        }
    </div>
</form>

@if (!Model.Page.Items.Any())
{
    <div class="bg-surface-container-low border border-outline-variant border-dashed rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center">
        <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline mb-4 border border-outline-variant">
            <span class="material-symbols-outlined text-[36px]">school</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm text-on-surface mb-1 font-bold">
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <span>Không tìm thấy môn học phù hợp</span>
            }
            else
            {
                <span>Chưa có môn học nào</span>
            }
        </h5>
        <p class="text-on-surface-variant max-w-xs text-xs">
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <span>Thử từ khóa khác hoặc </span>
                <a href="/Subject/MySubjects" class="text-primary hover:underline font-semibold">xem tất cả</a>
            }
            else
            {
                <span>Bạn chưa được phân công môn học nào. Liên hệ quản trị viên.</span>
            }
        </p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var subject in Model.Page.Items)
        {
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex flex-col gap-3 shadow-sm hover:border-primary/50 transition-all">
                <div class="flex justify-between items-start">
                    <div class="min-w-0">
                        <span class="font-mono text-[10px] text-primary font-bold tracking-wider uppercase">@subject.SubjectCode</span>
                        <h3 class="font-headline-sm text-base font-bold text-on-surface mt-1 leading-tight line-clamp-2">@subject.Name</h3>
                    </div>
                    <span class="bg-tertiary-container/20 border border-tertiary/20 text-tertiary text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">Hoạt động</span>
                </div>
                @if (!string.IsNullOrEmpty(subject.Description))
                {
                    <p class="text-xs text-on-surface-variant line-clamp-3 leading-relaxed">@subject.Description</p>
                }
                <div class="flex gap-2 mt-auto pt-3 border-t border-outline-variant/20">
                    <a asp-page="/Subject/Details" asp-route-id="@subject.Id" class="flex-1 bg-primary/10 hover:bg-primary text-primary hover:text-on-primary text-center font-label-md text-xs font-bold py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[16px]">info</span> Chi tiết
                    </a>
                    <a asp-page="/Subject/Chat" asp-route-subjectId="@subject.Id" class="px-3 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-lg text-on-surface transition-colors">
                        <span class="material-symbols-outlined text-[16px]">chat</span>
                    </a>
                </div>
            </div>
        }
    </div>

    ViewData["PagedResult"] = Model.Page;
    <partial name="_Pager" />
}
