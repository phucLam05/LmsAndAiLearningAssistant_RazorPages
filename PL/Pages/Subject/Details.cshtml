@page
@model PL.Pages.Subject.DetailsModel
@using Core.Entities
@using Core.DTOs.Documents
@{
    ViewData["Title"] = Model.Subject.Name;
    var canUpload = Model.UserRole == UserRole.Lecturer && Model.Subject.LecturerId == Model.CurrentUserId;
    var canDelete = Model.UserRole == UserRole.Lecturer;
    var backUrl = Model.UserRole switch
    {
        UserRole.Admin => "/Subject/Index",
        UserRole.Lecturer => "/Subject/MySubjects",
        _ => "/Subject/Browse"
    };
}

@functions {
    public static string FormatFileSize(long bytes)
    {
        if (bytes <= 0) return "0 Bytes";
        string[] suffixes = { "Bytes", "KB", "MB", "GB" };
        int counter = 0;
        double number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number = number / 1024;
            counter++;
            if (counter >= suffixes.Length - 1) break;
        }
        return $"{number:F1} {suffixes[counter]}";
    }
}

@Html.AntiForgeryToken()
<div class="max-w-6xl mx-auto space-y-6 select-none">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <a href="@backUrl" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-on-surface text-xs font-semibold mb-2 block w-fit">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span> Quay lại danh sách
            </a>
            <div class="mt-1">
                <span class="font-mono text-[10px] text-primary font-bold tracking-wider uppercase bg-primary/10 px-2.5 py-0.5 rounded-lg border border-primary/20">@Model.Subject.SubjectCode</span>
            </div>
            <h1 class="font-headline-lg text-headline-lg font-bold text-on-surface mt-1 tracking-tight">@Model.Subject.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Subject.Description))
            {
                <p class="text-xs text-on-surface-variant mt-1 max-w-2xl">@Model.Subject.Description</p>
            }
        </div>
        @if (Model.UserRole == UserRole.Student)
        {
            <a asp-page="/Subject/Chat" asp-route-subjectId="@Model.Subject.Id" class="bg-primary text-on-primary px-5 py-2.5 rounded-xl font-label-md text-xs font-bold transition-all shadow-sm hover:scale-[1.02] flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px]">chat</span> Bắt đầu trò chuyện
            </a>
        }
    </div>

    @if (canUpload)
    {
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm upload-card">
            <h3 class="font-headline-sm text-base font-bold text-on-surface mb-3">Tải lên tài liệu mới</h3>
            <div id="uploadDropzone" class="border-2 border-dashed border-outline-variant hover:border-primary/50 rounded-xl p-8 text-center cursor-pointer transition-all">
                <span class="material-symbols-outlined text-[48px] text-outline">cloud_upload</span>
                <p class="text-sm text-on-surface-variant mt-2">Kéo thả một hoặc nhiều tệp vào đây hoặc <span class="text-primary font-bold">nhấn để chọn</span></p>
                <p class="text-[10px] text-outline mt-1">PDF, DOCX, PPTX, TXT, MD — tối đa 50MB / tệp</p>
            </div>
            <input type="file" id="fileInput" multiple accept=".pdf,.doc,.docx,.ppt,.pptx,.txt,.md,.csv,.json,.xml,.rtf" class="hidden" />
        </div>
    }

    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm">
        <h3 class="font-headline-sm text-base font-bold text-on-surface mb-3">Tài liệu của môn học (@Model.Documents.Count)</h3>
        @if (!Model.Documents.Any())
        {
            <p class="text-xs text-on-surface-variant text-center py-8">Chưa có tài liệu nào.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-surface-container-lowest border-b border-outline-variant/50">
                            <th class="p-3 text-label-md font-semibold text-on-surface-variant uppercase">Tên</th>
                            <th class="p-3 text-label-md font-semibold text-on-surface-variant uppercase hidden sm:table-cell">Kích thước</th>
                            <th class="p-3 text-label-md font-semibold text-on-surface-variant uppercase">Trạng thái</th>
                            <th class="p-3 text-label-md font-semibold text-on-surface-variant uppercase text-right pr-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/30">
                        @foreach (var doc in Model.Documents)
                        {
                            var statusText = doc.Status switch
                            {
                                DocumentStatus.Success => "Thành công",
                                DocumentStatus.Failed => "Thất bại",
                                DocumentStatus.Processing => "Đang xử lý",
                                DocumentStatus.Pending => "Đang chờ",
                                _ => doc.Status.ToString()
                            };
                            var statusClass = doc.Status switch
                            {
                                DocumentStatus.Success => "bg-tertiary-container/20 border-tertiary/20 text-tertiary",
                                DocumentStatus.Failed => "bg-error-container/20 border-error/20 text-error",
                                DocumentStatus.Processing => "bg-blue-500/10 border-blue-500/20 text-blue-500",
                                _ => "bg-yellow-500/10 border-yellow-500/20 text-yellow-500"
                            };
                            <tr id="doc-@doc.Id">
                                <td class="p-3">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px] text-primary">description</span>
                                        <a asp-page="/Document/Details" asp-route-id="@doc.Id" class="text-xs text-on-surface hover:text-primary truncate max-w-xs">@doc.FileName</a>
                                    </div>
                                </td>
                                <td class="p-3 text-xs text-on-surface-variant hidden sm:table-cell">@FormatFileSize(doc.FileSize)</td>
                                <td class="p-3">
                                    <span class="doc-status inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[10px] font-semibold @statusClass">
                                        @if (doc.Status == DocumentStatus.Processing)
                                        {
                                            <span class="w-3 h-3 border-2 border-t-transparent border-blue-500 rounded-full animate-spin"></span>
                                        }
                                        <span class="doc-status-text">@statusText</span>
                                    </span>
                                </td>
                                <td class="p-3 text-right">
                                    <div class="inline-flex gap-1">
                                        <a asp-page="/Document/ViewOriginal" asp-route-id="@doc.Id" target="_blank" class="p-1 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-on-surface-variant" title="Tải xuống">
                                            <span class="material-symbols-outlined text-[14px]">download</span>
                                        </a>
                                        @if (doc.Status == DocumentStatus.Failed && canUpload)
                                        {
                                            <form method="post" asp-page-handler="Retry" asp-page="/Document/Details" asp-route-id="@doc.Id" asp-route-subjectId="@Model.Subject.Id" class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="p-1 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-primary" title="Thử lại">
                                                    <span class="material-symbols-outlined text-[14px]">refresh</span>
                                                </button>
                                            </form>
                                        }
                                        @if (canDelete && Model.UserRole == UserRole.Lecturer)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-page="/Document/Details" asp-route-id="@doc.Id" asp-route-subjectId="@Model.Subject.Id" class="inline" data-confirm="Bạn có chắc muốn xóa tài liệu @doc.FileName?">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="p-1 bg-surface border border-outline-variant hover:bg-error-container/20 rounded text-error" title="Xóa">
                                                    <span class="material-symbols-outlined text-[14px]">delete</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        LmsUpload.bindDropzone({
            dropzoneId: 'uploadDropzone',
            fileInputId: 'fileInput',
            cardSelector: '.upload-card',
            uploadUrl: '?handler=UploadFile',
            token: token,
            subjectId: '@Model.Subject.Id',
            fieldName: 'file'
        });
        LmsUpload.pollDocumentStatus('?handler=GetStatus', token);
    </script>
}
