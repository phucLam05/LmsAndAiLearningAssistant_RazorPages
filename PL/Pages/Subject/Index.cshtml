@page
@model PL.Pages.Subject.IndexModel
@using Core.DTOs.Subject
@using Core.Entities
@{
    ViewData["Title"] = Model.IsAdminMode ? "Quản lý Môn học" : "Môn học của tôi";
    var role = Model.UserRole;
    var isAdmin = role == UserRole.Admin;
    var isLecturer = role == UserRole.Lecturer;
    var isStudent = role == UserRole.Student;
}
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 select-none">
    <div>
        <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-[10px] font-mono font-bold tracking-tight uppercase">
            @(isAdmin ? "Bảng điều khiển Admin" : isLecturer ? "Giảng viên" : "Sinh viên")
        </span>
        <h1 class="font-headline-lg text-headline-lg md:font-display-lg md:text-display-lg font-bold text-on-surface mt-2 tracking-tight">
            @(isAdmin ? "Quản lý Môn học" : isLecturer ? "Môn học của tôi" : "Khám phá môn học")
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">
            @(isAdmin ? "Tạo mới, chỉnh sửa, phân công giảng viên cho các môn học trong hệ thống." :
              isLecturer ? "Danh sách các môn học bạn được phân công phụ trách. Upload tài liệu để AI có thể hỗ trợ sinh viên." :
              "Danh sách các môn học đang hoạt động. Chọn một môn để bắt đầu trò chuyện với AI.")
        </p>
    </div>

    @if (isAdmin)
    {
        <button type="button" onclick="openModal('createSubjectModal')" class="bg-primary text-on-primary font-label-md text-label-md px-5 py-2.5 rounded-full hover:bg-primary-fixed hover:text-on-primary-fixed transition-all duration-200 flex items-center gap-2 font-medium shadow-sm hover:scale-[1.02]">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Tạo môn học mới
        </button>
    }
</div>

<form method="get" class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-3 mb-6 shadow-sm select-none">
    <input type="hidden" name="pageIndex" value="1" />
    <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-outline text-[20px]">search</span>
        </div>
        <input type="text" name="search" value="@Model.Search" class="w-full bg-surface border border-outline-variant/50 text-on-surface rounded-xl pl-10 pr-10 py-2.5 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder:text-outline/50 text-sm" placeholder="Tìm tên môn học, mã môn học hoặc giảng viên..." />
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <a href="/Subject/Index" class="absolute inset-y-0 right-0 pr-3 flex items-center text-outline hover:text-on-surface">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </a>
        }
    </div>
</form>

<!-- Subject grid -->
@if (!Model.Page.Items.Any())
{
    <div class="bg-surface-container-low border border-outline-variant border-dashed rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center">
        <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline mb-4 border border-outline-variant">
            <span class="material-symbols-outlined text-[36px]">school</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm text-on-surface mb-1 font-bold">
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <span>Không tìm thấy môn học phù hợp</span>
            }
            else
            {
                <span>Chưa có môn học nào</span>
            }
        </h5>
        <p class="text-on-surface-variant max-w-xs text-xs">
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <span>Thử từ khóa khác hoặc </span>
                <a href="/Subject/Index" class="text-primary hover:underline font-semibold">xem tất cả</a>
            }
            else
            {
                @(isAdmin ? "Hãy tạo môn học đầu tiên của bạn bằng nút phía trên." :
                  isLecturer ? "Bạn chưa được phân công môn học nào. Liên hệ quản trị viên." :
                  "Chưa có môn học hoạt động nào. Vui lòng quay lại sau.")
            }
        </p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="subjectGrid">
        @foreach (var subject in Model.Page.Items)
        {
            var statusText = subject.Status == Core.Entities.SubjectStatus.Active ? "Hoạt động" : "Ngừng";
            <div class="subject-card bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex flex-col gap-3 shadow-sm hover:border-primary/50 transition-all"
                 data-name="@subject.Name.ToLower()" data-code="@subject.SubjectCode?.ToLower()" data-lecturer="@(subject.LecturerName?.ToLower() ?? "")">
                <div class="flex justify-between items-start">
                    <div class="min-w-0">
                        <span class="font-mono text-[10px] text-primary font-bold tracking-wider uppercase">@subject.SubjectCode</span>
                        <h3 class="font-headline-sm text-base font-bold text-on-surface mt-1 leading-tight line-clamp-2">@subject.Name</h3>
                    </div>
                    <span class="bg-tertiary-container/20 border border-tertiary/20 text-tertiary text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">@statusText</span>
                </div>
                @if (!string.IsNullOrEmpty(subject.Description))
                {
                    <p class="text-xs text-on-surface-variant line-clamp-3 leading-relaxed">@subject.Description</p>
                }
                <div class="flex items-center gap-2 mt-1 text-[11px] text-outline">
                    <span class="material-symbols-outlined text-[14px]">person</span>
                    <span class="truncate">@(subject.LecturerName ?? "Chưa phân công")</span>
                </div>
                @if (isAdmin)
                {
                    <form method="post" asp-page-handler="AssignLecturer" asp-route-subjectId="@subject.Id" class="flex items-center gap-1.5 mt-2" data-confirm-empty="Bỏ phân công giảng viên cho môn này?">
                        @Html.AntiForgeryToken()
                        <select name="lecturerId" class="flex-1 min-w-0 bg-surface border border-outline-variant/50 rounded-lg px-2 py-1.5 text-on-surface text-[11px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" title="Phân công giảng viên">
                            <option value="">— Chưa phân công —</option>
                            @foreach (var lec in Model.Lecturers)
                            {
                                if (subject.LecturerId.HasValue && lec.Id == subject.LecturerId.Value)
                                {
                                    <option value="@lec.Id" selected>@lec.FullName</option>
                                }
                                else
                                {
                                    <option value="@lec.Id">@lec.FullName</option>
                                }
                            }
                        </select>
                        <button type="submit" class="bg-primary/10 hover:bg-primary text-primary hover:text-on-primary px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-colors flex items-center gap-1" title="Lưu phân công">
                            <span class="material-symbols-outlined text-[14px]">save</span>
                        </button>
                    </form>
                }
                <div class="flex gap-2 mt-auto pt-3 border-t border-outline-variant/20">
                    <a asp-page="/Subject/Details" asp-route-id="@subject.Id" class="flex-1 bg-primary/10 hover:bg-primary text-primary hover:text-on-primary text-center font-label-md text-xs font-bold py-2 rounded-lg transition-colors">
                        @if (isStudent) { <span>Trò chuyện</span> } else { <span>Chi tiết</span> }
                    </a>
                    @if (isAdmin)
                    {
                        <button type="button" onclick="prepareEditModal('@subject.Id', '@subject.Name', '@subject.Description', '@subject.LecturerId', '@subject.Status')" class="px-3 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-lg text-on-surface transition-colors" title="Sửa">
                            <span class="material-symbols-outlined text-[16px]">edit</span>
                        </button>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@subject.Id" class="inline" data-confirm="Bạn có chắc chắn muốn xóa môn học @subject.Name?">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="px-3 bg-surface border border-outline-variant hover:bg-error-container/20 rounded-lg text-error transition-colors" title="Xóa">
                                <span class="material-symbols-outlined text-[16px]">delete</span>
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>

    ViewData["PagedResult"] = Model.Page;
    <partial name="_Pager" />
}

@if (isAdmin)
{
    <!-- Modal: Create Subject -->
    <div id="createSubjectModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 hidden select-none animate-fade-in">
        <div class="bg-surface-container-low border border-outline-variant/40 rounded-2xl w-full max-w-[480px] overflow-hidden shadow-2xl">
            <form method="post" asp-page-handler="Create" class="m-0">
                @Html.AntiForgeryToken()
                <div class="px-6 py-4 border-b border-outline-variant/30 flex justify-between items-center">
                    <h5 class="font-headline-sm text-base font-bold text-on-surface">Tạo môn học mới</h5>
                    <button type="button" onclick="closeModal('createSubjectModal')" class="text-on-surface-variant hover:text-on-surface">
                        <span class="material-symbols-outlined text-[20px] block">close</span>
                    </button>
                </div>
                <div class="p-6 space-y-4">
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Mã môn học</label>
                        <input type="text" name="SubjectCode" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" placeholder="VD: PRN222" required />
                    </div>
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Tên môn học</label>
                        <input type="text" name="Name" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" placeholder="VD: Lập trình .NET" required />
                    </div>
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Mô tả</label>
                        <textarea name="Description" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" rows="3" placeholder="Mô tả ngắn về môn học..."></textarea>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Giảng viên phụ trách</label>
                        <select name="LecturerId" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs">
                            <option value="">— Chưa phân công —</option>
                            @foreach (var lec in Model.Lecturers)
                            {
                                <option value="@lec.Id">@lec.FullName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-outline-variant/30 flex justify-end gap-2">
                    <button type="button" onclick="closeModal('createSubjectModal')" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface px-4 py-2 rounded-lg font-label-md text-xs transition-colors">Hủy</button>
                    <button type="submit" class="bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed px-4 py-2 rounded-lg font-label-md text-xs font-semibold transition-colors">Tạo mới</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal: Edit Subject -->
    <div id="editSubjectModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 hidden select-none animate-fade-in">
        <div class="bg-surface-container-low border border-outline-variant/40 rounded-2xl w-full max-w-[480px] overflow-hidden shadow-2xl">
            <form method="post" asp-page-handler="Edit" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editSubjectId" name="Id" />
                <div class="px-6 py-4 border-b border-outline-variant/30 flex justify-between items-center">
                    <h5 class="font-headline-sm text-base font-bold text-on-surface">Chỉnh sửa môn học</h5>
                    <button type="button" onclick="closeModal('editSubjectModal')" class="text-on-surface-variant hover:text-on-surface">
                        <span class="material-symbols-outlined text-[20px] block">close</span>
                    </button>
                </div>
                <div class="p-6 space-y-4">
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Tên môn học</label>
                        <input type="text" id="editName" name="Name" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" required />
                    </div>
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Mô tả</label>
                        <textarea id="editDescription" name="Description" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" rows="3"></textarea>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Giảng viên phụ trách</label>
                        <select id="editLecturerId" name="LecturerId" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs">
                            <option value="">— Chưa phân công —</option>
                            @foreach (var lec in Model.Lecturers)
                            {
                                <option value="@lec.Id">@lec.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-label-md font-bold text-on-surface-variant text-[11px]">Trạng thái</label>
                        <select id="editStatus" name="Status" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs">
                            <option value="Active">Hoạt động</option>
                            <option value="Inactive">Ngừng</option>
                        </select>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-outline-variant/30 flex justify-end gap-2">
                    <button type="button" onclick="closeModal('editSubjectModal')" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface px-4 py-2 rounded-lg font-label-md text-xs transition-colors">Hủy</button>
                    <button type="submit" class="bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed px-4 py-2 rounded-lg font-label-md text-xs font-semibold transition-colors">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id)?.classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }
        function prepareEditModal(id, name, description, lecturerId, status) {
            document.getElementById('editSubjectId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editDescription').value = description || '';
            document.getElementById('editLecturerId').value = lecturerId || '';
            document.getElementById('editStatus').value = status || 'Active';
            openModal('editSubjectModal');
        }
    </script>
}
