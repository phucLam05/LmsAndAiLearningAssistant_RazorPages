@page
@model PL.Pages.Admin.DocumentsModel
@using Core.DTOs.Common
@using Core.Entities
@{
    ViewData["Title"] = "Quản lý Tài liệu";
    var totalCount = Model.Page.TotalCount;
}

@functions {
    public static string FormatFileSize(long bytes)
    {
        if (bytes <= 0) return "0 Bytes";
        string[] suffixes = { "Bytes", "KB", "MB", "GB" };
        int counter = 0;
        double number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number = number / 1024;
            counter++;
            if (counter >= suffixes.Length - 1) break;
        }
        return $"{number:F1} {suffixes[counter]}";
    }
}

<div class="mb-6 select-none flex items-center gap-3">
    <div class="w-12 h-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
        <span class="material-symbols-outlined text-[28px]" style="font-variation-settings: 'FILL' 1;">description</span>
    </div>
    <div>
        <h1 class="font-headline-md text-headline-md font-bold text-on-surface">Quản lý Tài liệu Hệ thống</h1>
        <p class="text-xs text-on-surface-variant mt-0.5">Quản trị toàn bộ tệp tin học liệu, cấu trúc chunks, và trạng thái đồng bộ hóa vector AI.</p>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8 select-none">
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex items-center gap-4 shadow-sm hover:border-outline-variant/60 transition-colors">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary border border-primary/20">
            <span class="material-symbols-outlined text-[24px]">folder_open</span>
        </div>
        <div>
            <span class="text-outline text-xs block mb-0.5">Tổng số tài liệu</span>
            <strong class="font-headline-sm text-headline-sm text-on-surface font-bold">@totalCount</strong>
        </div>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex items-center gap-4 shadow-sm hover:border-outline-variant/60 transition-colors">
        <div class="w-12 h-12 rounded-xl bg-tertiary/10 flex items-center justify-center text-tertiary border border-tertiary/20">
            <span class="material-symbols-outlined text-[24px]">sd_card</span>
        </div>
        <div>
            <span class="text-outline text-xs block mb-0.5">Dung lượng lưu trữ</span>
            <strong class="font-headline-sm text-headline-sm text-on-surface font-bold">@FormatFileSize(Model.TotalSizeBytes)</strong>
        </div>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex items-center gap-4 shadow-sm hover:border-outline-variant/60 transition-colors">
        <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center text-green-400 border border-green-500/20">
            <span class="material-symbols-outlined text-[24px] filled">check_circle</span>
        </div>
        <div>
            <span class="text-outline text-xs block mb-0.5">Đã phân tích AI</span>
            <strong class="font-headline-sm text-headline-sm text-on-surface font-bold">@Model.SuccessCount <span class="text-xs text-outline font-normal">/ @totalCount</span></strong>
        </div>
    </div>
</div>

<form method="get" class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-4 mb-6 shadow-sm select-none">
    <input type="hidden" name="pageIndex" value="1" />
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
        <div class="relative w-full md:max-w-md">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-outline text-[20px]">search</span>
            </div>
            <input type="text" name="search" value="@Model.Search" class="w-full bg-surface border border-outline-variant/50 text-on-surface rounded-xl pl-10 pr-4 py-2.5 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder:text-outline/50 text-sm" placeholder="Tìm tên tài liệu, mã hoặc tên môn học..." />
        </div>
        <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-1 md:pb-0">
            @{
                string StatusLink(string? s) => Url.Page("/Admin/Documents", new { Search = Model.Search, Status = s, pageIndex = 1 }) ?? "#";
                string TabClass(string? s)
                {
                    bool active = (string.IsNullOrEmpty(s) && string.IsNullOrEmpty(Model.Status))
                                  || string.Equals(s, Model.Status, StringComparison.OrdinalIgnoreCase);
                    return active
                        ? "px-4 py-2 rounded-xl text-xs font-semibold bg-primary text-on-primary hover:scale-[1.01] transition-all whitespace-nowrap cursor-pointer"
                        : "px-4 py-2 rounded-xl text-xs font-semibold bg-surface border border-outline-variant/50 text-on-surface-variant hover:bg-surface-container-highest transition-all whitespace-nowrap cursor-pointer";
                }
            }
            <a href="@StatusLink(null)" class="@TabClass(null)">Tất cả (@totalCount)</a>
            <a href="@StatusLink("Success")" class="@TabClass("Success")">Thành công (@Model.SuccessCount)</a>
            <a href="@StatusLink("Processing")" class="@TabClass("Processing")">Đang xử lý (@Model.ProcessingCount)</a>
            <a href="@StatusLink("Failed")" class="@TabClass("Failed")">Thất bại (@Model.FailedCount)</a>
        </div>
    </div>
    <div class="mt-2 flex justify-end">
        <button type="submit" class="bg-primary text-on-primary font-bold px-3 py-1.5 rounded-lg text-[11px] font-semibold hover:bg-primary-fixed transition-colors">Áp dụng</button>
    </div>
</form>

@if (!Model.Page.Items.Any())
{
    <div class="bg-surface-container-low border border-outline-variant border-dashed rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center">
        <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline mb-4 border border-outline-variant">
            <span class="material-symbols-outlined text-[36px]">folder_off</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm text-on-surface mb-1 font-bold">Không có tài liệu nào trong hệ thống</h5>
        <p class="text-on-surface-variant max-w-xs text-xs">
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Status))
            {
                <span>Không có tài liệu nào khớp với bộ lọc hiện tại. </span>
                <a href="/Admin/Documents" class="text-primary hover:underline font-semibold">Xóa bộ lọc</a>
            }
            else
            {
                <span>Hiện tại chưa có môn học nào được upload tài liệu học tập lên máy chủ.</span>
            }
        </p>
    </div>
}
else
{
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse" id="docsTable">
                <thead>
                    <tr class="bg-surface-container-lowest border-b border-outline-variant/50 select-none">
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Tên tài liệu</th>
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Môn học</th>
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider hidden sm:table-cell">Dung lượng</th>
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Người gửi</th>
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider hidden lg:table-cell">Ngày gửi</th>
                        <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant w-40 text-right pr-6">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/30">
                    @foreach (var doc in Model.Page.Items)
                    {
                        var fileExtension = System.IO.Path.GetExtension(doc.FileName).ToLower().TrimStart('.');
                        var iconName = fileExtension switch
                        {
                            "pdf" => "picture_as_pdf",
                            "docx" or "doc" => "description",
                            "pptx" or "ppt" => "slideshow",
                            "xlsx" or "xls" => "table_chart",
                            _ => "text_snippet"
                        };
                        var iconColorClass = fileExtension switch
                        {
                            "pdf" => "text-error",
                            "docx" or "doc" => "text-primary",
                            "pptx" or "ppt" => "text-secondary",
                            "xlsx" or "xls" => "text-tertiary",
                            _ => "text-outline"
                        };
                        <tr class="hover:bg-surface-container/30 transition-colors group">
                            <td class="p-4 align-middle">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded bg-surface-container flex items-center justify-center flex-shrink-0 @iconColorClass border border-outline-variant/20 select-none">
                                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">@iconName</span>
                                    </div>
                                    <div class="min-w-0">
                                        <a asp-page="/Document/Details" asp-route-id="@doc.Id" class="font-body-md text-body-md font-medium text-on-surface truncate hover:text-primary transition-colors max-w-[200px] sm:max-w-xs block" title="@doc.FileName">@doc.FileName</a>
                                        <div class="flex items-center gap-1.5 mt-0.5 text-[10px] text-outline sm:hidden select-none">
                                            <span>@doc.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            <span>&bull;</span>
                                            <span>@FormatFileSize(doc.FileSize)</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-4 align-middle font-body-md text-body-md text-on-surface">
                                <div class="max-w-[150px] truncate" title="@doc.SubjectCode - @doc.SubjectName">
                                    <span class="font-semibold text-primary">@doc.SubjectCode</span>
                                    <span class="text-outline text-xs block truncate">@doc.SubjectName</span>
                                </div>
                            </td>
                            <td class="p-4 align-middle hidden sm:table-cell font-body-md text-body-md text-on-surface-variant select-none">@FormatFileSize(doc.FileSize)</td>
                            <td class="p-4 align-middle font-body-md text-body-md text-on-surface-variant select-none">@(doc.UploaderName ?? "N/A")</td>
                            <td class="p-4 align-middle select-none">
                                @{
                                    var badgeColorClass = doc.Status switch
                                    {
                                        DocumentStatus.Success => "bg-tertiary-container/20 border-tertiary/20 text-tertiary",
                                        DocumentStatus.Failed => "bg-error-container/20 border-error/20 text-error",
                                        DocumentStatus.Processing => "bg-blue-500/10 border-blue-500/20 text-blue-500",
                                        _ => "bg-yellow-500/10 border-yellow-500/20 text-yellow-500"
                                    };
                                    var statusText = doc.Status switch
                                    {
                                        DocumentStatus.Success => "Thành công",
                                        DocumentStatus.Failed => "Thất bại",
                                        DocumentStatus.Processing => "Đang xử lý",
                                        DocumentStatus.Pending => "Đang chờ",
                                        _ => doc.Status.ToString()
                                    };
                                }
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full border text-[11px] font-semibold @badgeColorClass">
                                    @if (doc.Status == DocumentStatus.Processing)
                                    {
                                        <span class="w-3 h-3 border-2 border-t-transparent border-blue-500 rounded-full animate-spin"></span>
                                    }
                                    else
                                    {
                                        <span class="w-1.5 h-1.5 rounded-full @(doc.Status == DocumentStatus.Success ? "bg-tertiary" : doc.Status == DocumentStatus.Failed ? "bg-error" : "bg-yellow-500")"></span>
                                    }
                                    @statusText
                                </span>
                            </td>
                            <td class="p-4 align-middle hidden lg:table-cell font-body-md text-body-md text-on-surface-variant select-none">@doc.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td class="p-4 align-middle text-right pr-6 w-40">
                                <div class="inline-flex justify-end gap-2 items-center">
                                    <a asp-page="/Document/ViewOriginal" asp-route-id="@doc.Id" target="_blank" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-on-surface-variant transition-colors" title="Tải xuống file gốc">
                                        <span class="material-symbols-outlined text-[16px]">download</span>
                                    </a>
                                    <a asp-page="/Document/Details" asp-route-id="@doc.Id" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-on-surface-variant transition-colors" title="Xem danh sách chunks">
                                        <span class="material-symbols-outlined text-[16px]">list</span>
                                    </a>
                                    @if (doc.Status == DocumentStatus.Failed)
                                    {
                                        <form method="post" asp-page-handler="Retry" asp-route-id="@doc.Id" asp-route-subjectId="@doc.SubjectId" asp-route-redirectUrl="@(ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString)" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-primary transition-colors cursor-pointer" title="Thử lại AI indexing">
                                                <span class="material-symbols-outlined text-[16px]">refresh</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    ViewData["PagedResult"] = Model.Page;
    <partial name="_Pager" />
}
