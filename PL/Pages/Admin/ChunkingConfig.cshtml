@page
@model PL.Pages.Admin.ChunkingConfigModel
@{
    ViewData["Title"] = "Cấu hình Chunking - LMS AI";
}

<div class="font-sans max-w-5xl mx-auto space-y-6 select-none py-2 animate-fade-in">
    <!-- Navigation row and Breadcrumbs -->
    <div class="flex items-center justify-between px-1">
        <div class="flex items-center gap-3">
            <a href="/Admin/Index" class="inline-flex items-center gap-1.5 text-on-surface-variant hover:text-primary text-xs font-bold transition-all hover:-translate-x-0.5 duration-200">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span> Dashboard
            </a>
            <span class="text-outline-variant/50">/</span>
            <span class="text-xs text-outline font-medium">Cấu hình Chunking</span>
        </div>
    </div>

    <!-- Header Section with Glassmorphism and Gradients -->
    <div class="relative bg-surface-container-low border border-outline-variant/30 rounded-3xl p-6 sm:p-8 overflow-hidden shadow-xl">
        <div class="absolute -top-24 -left-24 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -right-24 w-48 h-48 bg-tertiary/10 rounded-full blur-3xl"></div>
        
        <div class="relative flex flex-col sm:flex-row items-start sm:items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/20 border border-primary/30 flex items-center justify-center text-primary shadow-inner shrink-0">
                <span class="material-symbols-outlined text-[32px] animate-pulse">settings_suggest</span>
            </div>
            <div class="space-y-1">
                <h1 class="font-headline-lg text-xl sm:text-2xl font-extrabold tracking-tight bg-gradient-to-r from-primary via-secondary to-tertiary bg-clip-text text-transparent">
                    Cấu hình Chunking Hệ thống
                </h1>
                <p class="text-xs text-on-surface-variant font-medium max-w-2xl leading-relaxed">
                    Điều chỉnh thuật toán phân tách văn bản thông minh. Chunking chuẩn xác giúp mô hình AI dễ dàng truy xuất thông tin ngữ nghĩa và trả lời chính xác hơn.
                </p>
            </div>
        </div>
    </div>

    <form method="post" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- Method Selector -->
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-3xl p-6 sm:p-8 shadow-xl">
            <div class="flex items-center gap-2 mb-6 pb-2 border-b border-outline-variant/20">
                <span class="material-symbols-outlined text-primary text-[20px]">layers</span>
                <h3 class="font-headline-sm text-sm sm:text-base font-bold text-on-surface">Phương pháp phân tách (Chunking Method)</h3>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5" id="methodGrid">
                <!-- Option 1: Paragraph -->
                <label class="relative flex flex-col p-5 bg-surface-container-lowest border-2 border-outline-variant/30 hover:border-primary/40 rounded-2xl cursor-pointer transition-all duration-300 select-none group hover:shadow-md hover:scale-[1.01]">
                    <input type="radio" asp-for="Config.Method" value="Paragraph" class="sr-only" id="radioParagraph" />
                    
                    <div class="flex items-center justify-between mb-4">
                        <span class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-[20px] filled">segment</span>
                        </span>
                        <span class="material-symbols-outlined text-primary text-[22px] opacity-0 scale-75 group-[.selected]:opacity-100 group-[.selected]:scale-100 transition-all duration-300 check-icon">check_circle</span>
                    </div>
                    
                    <span class="font-bold text-on-surface text-xs block">Paragraph (Đoạn văn)</span>
                    <span class="text-[11px] text-outline mt-2 leading-relaxed font-medium">
                        Phân tách dựa trên cấu trúc đoạn văn bản tự nhiên (\n\n). Khuyến nghị sử dụng để giữ nguyên cấu trúc ngữ nghĩa liền mạch.
                    </span>
                </label>

                <!-- Option 2: Word -->
                <label class="relative flex flex-col p-5 bg-surface-container-lowest border-2 border-outline-variant/30 hover:border-primary/40 rounded-2xl cursor-pointer transition-all duration-300 select-none group hover:shadow-md hover:scale-[1.01]">
                    <input type="radio" asp-for="Config.Method" value="Word" class="sr-only" id="radioWord" />
                    
                    <div class="flex items-center justify-between mb-4">
                        <span class="w-10 h-10 rounded-xl bg-secondary/10 text-secondary flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-[20px] filled">format_align_left</span>
                        </span>
                        <span class="material-symbols-outlined text-primary text-[22px] opacity-0 scale-75 group-[.selected]:opacity-100 group-[.selected]:scale-100 transition-all duration-300 check-icon">check_circle</span>
                    </div>
                    
                    <span class="font-bold text-on-surface text-xs block">Word (Số từ)</span>
                    <span class="text-[11px] text-outline mt-2 leading-relaxed font-medium">
                        Phân tách theo số lượng từ cố định. Đảm bảo dung lượng các khối dữ liệu bằng nhau tuyệt đối theo đơn vị từ vựng.
                    </span>
                </label>

                <!-- Option 3: Character -->
                <label class="relative flex flex-col p-5 bg-surface-container-lowest border-2 border-outline-variant/30 hover:border-primary/40 rounded-2xl cursor-pointer transition-all duration-300 select-none group hover:shadow-md hover:scale-[1.01]">
                    <input type="radio" asp-for="Config.Method" value="Character" class="sr-only" id="radioCharacter" />
                    
                    <div class="flex items-center justify-between mb-4">
                        <span class="w-10 h-10 rounded-xl bg-tertiary/10 text-tertiary flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-[20px] filled">match_word</span>
                        </span>
                        <span class="material-symbols-outlined text-primary text-[22px] opacity-0 scale-75 group-[.selected]:opacity-100 group-[.selected]:scale-100 transition-all duration-300 check-icon">check_circle</span>
                    </div>
                    
                    <span class="font-bold text-on-surface text-xs block">Character (Ký tự)</span>
                    <span class="text-[11px] text-outline mt-2 leading-relaxed font-medium">
                        Phân tách chuẩn xác theo giới hạn số lượng ký tự chữ cái. Thích hợp cho các cấu trúc văn bản đặc biệt cần xử lý độ dài thô.
                    </span>
                </label>
            </div>
            <span asp-validation-for="Config.Method" class="text-error text-xs mt-2 block font-medium"></span>
        </div>

        <!-- Size parameters and live visualizer -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Parameter Inputs Card -->
            <div class="lg:col-span-2 bg-surface-container-low border border-outline-variant/30 rounded-3xl p-6 sm:p-8 shadow-xl space-y-6">
                <div class="flex items-center gap-2 mb-2 pb-2 border-b border-outline-variant/20">
                    <span class="material-symbols-outlined text-primary text-[20px]">tune</span>
                    <h3 class="font-headline-sm text-sm sm:text-base font-bold text-on-surface">Tham số phân đoạn</h3>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="block font-bold text-on-surface text-[10px] tracking-wide uppercase" asp-for="Config.ChunkSize">Kích thước Chunk (Chunk Size)</label>
                        <div class="relative group">
                            <input type="number" asp-for="Config.ChunkSize" id="inputChunkSize" class="w-full bg-surface-container-high border-2 border-outline-variant/40 text-on-surface rounded-xl pl-4 pr-16 py-3.5 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-xs font-bold text-white shadow-inner" placeholder="VD: 500" />
                            <span class="absolute inset-y-0 right-4 flex items-center text-xs text-primary font-bold uppercase select-none tracking-wider transition-colors group-focus-within:text-primary" id="sizeUnit">tokens</span>
                        </div>
                        <span asp-validation-for="Config.ChunkSize" class="text-error text-xs mt-1 block font-medium"></span>
                        <p class="text-[10px] text-outline leading-relaxed font-semibold" id="sizeHelp">Kích thước tối đa của một đoạn cắt văn bản.</p>
                    </div>

                    <div class="space-y-2">
                        <label class="block font-bold text-on-surface text-[10px] tracking-wide uppercase" asp-for="Config.OverlapSize">Độ chồng lặp (Overlap Size)</label>
                        <div class="relative group">
                            <input type="number" asp-for="Config.OverlapSize" id="inputOverlapSize" class="w-full bg-surface-container-high border-2 border-outline-variant/40 text-on-surface rounded-xl pl-4 pr-16 py-3.5 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-xs font-bold text-white shadow-inner" placeholder="VD: 50" />
                            <span class="absolute inset-y-0 right-4 flex items-center text-xs text-primary font-bold uppercase select-none tracking-wider transition-colors group-focus-within:text-primary" id="overlapUnit">tokens</span>
                        </div>
                        <span asp-validation-for="Config.OverlapSize" class="text-error text-xs mt-1 block font-medium"></span>
                        <p class="text-[10px] text-outline leading-relaxed font-semibold" id="overlapHelp">Phần trùng lặp giữa 2 đoạn chunk liền nhau để giữ ngữ cảnh.</p>
                    </div>
                </div>
            </div>

            <!-- Live Preview / Visualizer Card -->
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-3xl p-6 shadow-xl flex flex-col justify-between space-y-6">
                <div>
                    <div class="flex items-center gap-2 mb-2 pb-2 border-b border-outline-variant/20">
                        <span class="material-symbols-outlined text-primary text-[20px]">preview</span>
                        <h3 class="font-headline-sm text-sm font-bold text-on-surface">Mô phỏng & Chỉnh nhanh</h3>
                    </div>
                    <p class="text-[10px] text-on-surface-variant leading-relaxed mb-4 font-semibold">
                        Biểu diễn tỷ lệ chồng lặp (Overlap). Bạn có thể **kéo thanh trượt bên dưới** để cập nhật nhanh thông số.
                    </p>

                    <!-- Visual Timeline Bar -->
                    <div class="space-y-4 py-2 mb-6" id="visualizerContainer">
                        <!-- Chunk 1 -->
                        <div class="space-y-1">
                            <div class="flex justify-between text-[9px] font-mono text-outline">
                                <span>Chunk 1</span>
                                <span id="labelC1">0 - 500</span>
                            </div>
                            <div class="w-full bg-surface-container-high rounded-lg h-5 overflow-hidden border border-outline-variant/20 relative shadow-inner">
                                <div class="bg-gradient-to-r from-primary/40 to-primary/80 h-full rounded-lg" style="width: 100%"></div>
                            </div>
                        </div>

                        <!-- Chunk 2 -->
                        <div class="space-y-1">
                            <div class="flex justify-between text-[9px] font-mono text-outline">
                                <span>Chunk 2</span>
                                <span id="labelC2">450 - 950</span>
                            </div>
                            <div class="w-full bg-surface-container-high rounded-lg h-5 overflow-hidden border border-outline-variant/20 relative shadow-inner">
                                <div class="bg-gradient-to-r from-secondary/40 to-secondary/80 h-full rounded-lg transition-all duration-300" id="barC2" style="width: 100%; margin-left: 0%"></div>
                                <!-- Overlap Area Shadow -->
                                <div class="absolute top-0 bottom-0 bg-yellow-500/20 border-l border-r border-yellow-500/40 transition-all duration-300" id="overlapBar1" style="left: 0%; width: 10%"></div>
                            </div>
                        </div>

                        <!-- Chunk 3 -->
                        <div class="space-y-1">
                            <div class="flex justify-between text-[9px] font-mono text-outline">
                                <span>Chunk 3</span>
                                <span id="labelC3">900 - 1400</span>
                            </div>
                            <div class="w-full bg-surface-container-high rounded-lg h-5 overflow-hidden border border-outline-variant/20 relative shadow-inner">
                                <div class="bg-gradient-to-r from-tertiary/40 to-tertiary/80 h-full rounded-lg transition-all duration-300" id="barC3" style="width: 100%; margin-left: 0%"></div>
                                <div class="absolute top-0 bottom-0 bg-yellow-500/20 border-l border-r border-yellow-500/40 transition-all duration-300" id="overlapBar2" style="left: 0%; width: 10%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Interactive Range Sliders -->
                    <div class="space-y-4 pt-4 border-t border-outline-variant/20">
                        <div class="space-y-1.5">
                            <div class="flex justify-between text-[10px] font-bold text-on-surface">
                                <span>Kéo chỉnh Chunk Size</span>
                                <span class="text-primary font-mono font-bold" id="sliderSizeVal">500</span>
                            </div>
                            <input type="range" id="sliderChunkSize" min="100" max="2000" step="50" value="500" class="w-full accent-primary h-1 bg-surface-container-high rounded-lg appearance-none cursor-pointer border border-outline-variant/20 shadow-inner" />
                        </div>
                        <div class="space-y-1.5">
                            <div class="flex justify-between text-[10px] font-bold text-on-surface">
                                <span>Kéo chỉnh Overlap Size</span>
                                <span class="text-secondary font-mono font-bold" id="sliderOverlapVal">50</span>
                            </div>
                            <input type="range" id="sliderOverlapSize" min="0" max="500" step="10" value="50" class="w-full accent-secondary h-1 bg-surface-container-high rounded-lg appearance-none cursor-pointer border border-outline-variant/20 shadow-inner" />
                        </div>
                    </div>
                </div>

                <div class="mt-6 pt-4 border-t border-outline-variant/20 flex items-center justify-between text-[9px] text-outline font-semibold select-none">
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 bg-primary/80 rounded"></span> Chunk gốc</span>
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 bg-yellow-500/20 border border-yellow-500/40 rounded"></span> Khớp đè (Overlap)</span>
                </div>
            </div>
        </div>

        <!-- Submit Button Row -->
        <div class="flex justify-end pt-2">
            <button type="submit" class="bg-gradient-to-r from-primary to-secondary text-on-primary hover:from-primary-fixed hover:to-secondary-fixed transition-all font-bold px-8 py-4 rounded-2xl text-xs flex items-center gap-2 cursor-pointer shadow-lg hover:shadow-primary/20 hover:scale-[1.02] active:scale-[0.99] duration-200">
                <span class="material-symbols-outlined text-[18px] font-bold">save</span> Lưu và Áp dụng Cấu hình
            </button>
        </div>
    </form>
</div>

<!-- Beautiful Custom Alerts using system layout handler -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof showNotification === 'function') {
                showNotification("@Model.SuccessMessage", "success");
            }
        });
    </script>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof showNotification === 'function') {
                showNotification("@Model.ErrorMessage", "error");
            }
        });
    </script>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const inputs = document.querySelectorAll('input[name="Config.Method"]');
            const sizeUnit = document.getElementById('sizeUnit');
            const overlapUnit = document.getElementById('overlapUnit');
            const sizeHelp = document.getElementById('sizeHelp');
            const overlapHelp = document.getElementById('overlapHelp');
            
            // Visualizer & Slider elements
            const inputChunkSize = document.getElementById('inputChunkSize');
            const inputOverlapSize = document.getElementById('inputOverlapSize');
            const sliderChunkSize = document.getElementById('sliderChunkSize');
            const sliderOverlapSize = document.getElementById('sliderOverlapSize');
            const sliderSizeVal = document.getElementById('sliderSizeVal');
            const sliderOverlapVal = document.getElementById('sliderOverlapVal');
            
            const labelC1 = document.getElementById('labelC1');
            const labelC2 = document.getElementById('labelC2');
            const labelC3 = document.getElementById('labelC3');
            
            const barC2 = document.getElementById('barC2');
            const barC3 = document.getElementById('barC3');
            const overlapBar1 = document.getElementById('overlapBar1');
            const overlapBar2 = document.getElementById('overlapBar2');

            function updateSliderRanges(method) {
                const currentSize = parseInt(inputChunkSize.value) || 500;
                const currentOverlap = parseInt(inputOverlapSize.value) || 50;

                if (method === 'Paragraph') {
                    sliderChunkSize.min = 100;
                    sliderChunkSize.max = 2000;
                    sliderChunkSize.step = 50;
                    
                    sliderOverlapSize.min = 0;
                    sliderOverlapSize.max = 500;
                    sliderOverlapSize.step = 10;
                } else if (method === 'Word') {
                    sliderChunkSize.min = 20;
                    sliderChunkSize.max = 500;
                    sliderChunkSize.step = 10;
                    
                    sliderOverlapSize.min = 0;
                    sliderOverlapSize.max = 150;
                    sliderOverlapSize.step = 5;
                } else if (method === 'Character') {
                    sliderChunkSize.min = 100;
                    sliderChunkSize.max = 5000;
                    sliderChunkSize.step = 100;
                    
                    sliderOverlapSize.min = 0;
                    sliderOverlapSize.max = 1000;
                    sliderOverlapSize.step = 10;
                }

                // Guard values
                if (currentSize > sliderChunkSize.max) inputChunkSize.value = sliderChunkSize.max;
                if (currentSize < sliderChunkSize.min) inputChunkSize.value = sliderChunkSize.min;
                if (currentOverlap > sliderOverlapSize.max) inputOverlapSize.value = sliderOverlapSize.max;

                sliderChunkSize.value = inputChunkSize.value;
                sliderOverlapSize.value = inputOverlapSize.value;
                sliderSizeVal.textContent = inputChunkSize.value;
                sliderOverlapVal.textContent = inputOverlapSize.value;
            }

            function updateUI() {
                inputs.forEach(input => {
                    const label = input.closest('label');
                    if (input.checked) {
                        label.classList.add('selected', 'border-primary', 'bg-primary/5', 'ring-2', 'ring-primary/25');
                        label.classList.remove('border-outline-variant/30');
                        
                        const val = input.value;
                        updateSliderRanges(val);

                        if (val === 'Paragraph') {
                            sizeUnit.textContent = 'tokens';
                            overlapUnit.textContent = 'tokens';
                            sizeHelp.textContent = 'Kích thước tối đa của một đoạn cắt tính bằng số tokens (1 token ≈ 4 ký tự). Khuyến nghị: 500.';
                            overlapHelp.textContent = 'Độ chồng lặp giữa các đoạn kề nhau tính bằng tokens. Khuyến nghị: 50.';
                        } else if (val === 'Word') {
                            sizeUnit.textContent = 'từ';
                            overlapUnit.textContent = 'từ';
                            sizeHelp.textContent = 'Kích thước tối đa của một đoạn cắt tính bằng số từ. Khuyến nghị: 150 - 300 từ.';
                            overlapHelp.textContent = 'Độ chồng lặp tính bằng số từ để tránh mất ngữ cảnh. Khuyến nghị: 15 - 30 từ.';
                        } else if (val === 'Character') {
                            sizeUnit.textContent = 'ký tự';
                            overlapUnit.textContent = 'ký tự';
                            sizeHelp.textContent = 'Kích thước tối đa của một đoạn cắt tính bằng số ký tự thô. Khuyến nghị: 500 - 1000 ký tự.';
                            overlapHelp.textContent = 'Độ chồng lặp tính bằng số ký tự chữ cái. Khuyến nghị: 50 - 100 ký tự.';
                        }
                    } else {
                        label.classList.remove('selected', 'border-primary', 'bg-primary/5', 'ring-2', 'ring-primary/25');
                        label.classList.add('border-outline-variant/30');
                    }
                });
                
                updateVisualizer();
            }

            function updateVisualizer() {
                const size = parseInt(inputChunkSize.value) || 500;
                const overlap = parseInt(inputOverlapSize.value) || 0;
                
                // Guard: overlap can't be larger than size
                const safeOverlap = Math.min(overlap, size - 1);
                const step = size - safeOverlap;
                
                // Chunk ranges
                labelC1.textContent = `0 - ${size}`;
                
                const c2Start = step;
                const c2End = step + size;
                labelC2.textContent = `${c2Start} - ${c2End}`;
                
                const c3Start = 2 * step;
                const c3End = 2 * step + size;
                labelC3.textContent = `${c3Start} - ${c3End}`;
                
                // Visualization math
                const totalSpan = c3End || 1;
                const wPct = (size / totalSpan) * 100;
                const offsetC2Pct = (c2Start / totalSpan) * 100;
                const offsetC3Pct = (c3Start / totalSpan) * 100;
                
                barC2.style.width = `${wPct}%`;
                barC2.style.marginLeft = `${offsetC2Pct}%`;
                
                barC3.style.width = `${wPct}%`;
                barC3.style.marginLeft = `${offsetC3Pct}%`;
                
                const overlapWidthPct = (safeOverlap / totalSpan) * 100;
                
                overlapBar1.style.left = `${offsetC2Pct}%`;
                overlapBar1.style.width = `${overlapWidthPct}%`;
                
                overlapBar2.style.left = `${offsetC3Pct}%`;
                overlapBar2.style.width = `${overlapWidthPct}%`;
            }

            // Sync Sliders -> Input boxes & Val Labels
            sliderChunkSize.addEventListener('input', function() {
                inputChunkSize.value = this.value;
                sliderSizeVal.textContent = this.value;
                updateVisualizer();
            });
            sliderOverlapSize.addEventListener('input', function() {
                // Keep overlap smaller than size
                const currentSize = parseInt(inputChunkSize.value) || 500;
                if (parseInt(this.value) >= currentSize) {
                    this.value = currentSize - 1;
                }
                inputOverlapSize.value = this.value;
                sliderOverlapVal.textContent = this.value;
                updateVisualizer();
            });

            // Sync Input boxes -> Sliders & Val Labels
            inputChunkSize.addEventListener('input', function() {
                let val = parseInt(this.value) || 0;
                if (val > sliderChunkSize.max) val = sliderChunkSize.max;
                sliderChunkSize.value = val;
                sliderSizeVal.textContent = val;
                
                // Adjust overlap if it exceeds size
                const overlapVal = parseInt(inputOverlapSize.value) || 0;
                if (overlapVal >= val) {
                    inputOverlapSize.value = Math.max(0, val - 1);
                    sliderOverlapSize.value = inputOverlapSize.value;
                    sliderOverlapVal.textContent = inputOverlapSize.value;
                }
                updateVisualizer();
            });
            inputOverlapSize.addEventListener('input', function() {
                const currentSize = parseInt(inputChunkSize.value) || 500;
                let val = parseInt(this.value) || 0;
                if (val >= currentSize) {
                    val = currentSize - 1;
                    this.value = val;
                }
                if (val > sliderOverlapSize.max) val = sliderOverlapSize.max;
                sliderOverlapSize.value = val;
                sliderOverlapVal.textContent = val;
                updateVisualizer();
            });

            inputs.forEach(input => {
                input.addEventListener('change', updateUI);
            });

            // Initial trigger
            updateUI();
        });
    </script>
}
