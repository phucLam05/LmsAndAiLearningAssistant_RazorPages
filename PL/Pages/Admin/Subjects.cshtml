@section Scripts {
    <script>
        function openEditModal(id, code, name, desc, status, lecturerId) {
            document.getElementById('editId').value = id;
            document.getElementById('editCode').value = code;
            document.getElementById('editName').value = name;
            document.getElementById('editDesc').value = desc || '';
            document.getElementById('editStatus').value = status;
            document.getElementById('editLec').value = lecturerId || '';
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
        function openAssignModal(subjectId, subjectCode, currentLecId) {
            document.getElementById('assignSubjectId').value = subjectId;
            document.getElementById('assignSubjectCode').textContent = subjectCode;
            document.getElementById('assignLec').value = currentLecId || '';
            new bootstrap.Modal(document.getElementById('assignModal')).show();
        }
    </script>
}
