@page
@model PL.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Bảng điều khiển Quản trị";

    string FormatBytes(long bytes)
    {
        if (bytes <= 0) return "0 B";
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int unit = 0;
        while (size >= 1024 && unit < units.Length - 1) { size /= 1024; unit++; }
        return $"{size:0.##} {units[unit]}";
    }
    string FormatNumber(long n) => n >= 1000 ? $"{n:N0}" : n.ToString();
}

<div class="space-y-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 select-none">
        <div>
            <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-xs font-mono font-bold tracking-tight">
                Bảng điều khiển Admin
            </span>
            <h1 class="font-headline-lg text-headline-lg md:font-display-lg md:text-display-lg font-bold text-on-surface mt-2 tracking-tight">
                Xin chào, @Model.CurrentAdminFullName
            </h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-1 flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px]">workspace_premium</span>
                <span>Vai trò: <strong class="text-primary">@Model.CurrentAdminRole</strong></span>
                @if (!string.IsNullOrEmpty(Model.CurrentAdminEmail))
                {
                    <span class="text-outline">·</span>
                    <span class="font-mono">@Model.CurrentAdminEmail</span>
                }
            </p>
        </div>
        <div class="flex gap-2">
            <a asp-page="/Admin/Users" class="bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed text-xs font-semibold px-4 py-2.5 rounded-lg shadow-sm flex items-center gap-1.5">
                <span class="material-symbols-outlined text-[16px]">group</span> Quản lý người dùng
            </a>
            <a href="/hangfire" target="_blank" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface text-xs font-semibold px-4 py-2.5 rounded-lg flex items-center gap-1.5">
                <span class="material-symbols-outlined text-[16px]">open_in_new</span> Hangfire
            </a>
        </div>
    </div>

    <!-- ── Headline stat cards ── -->
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-4 select-none">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-[64px] text-primary">group</span>
            </div>
            <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Tổng người dùng</p>
            <h3 class="font-headline-lg text-headline-lg font-bold text-on-surface">@FormatNumber(Model.Stats.TotalUsers)</h3>
            <p class="font-label-md text-label-md text-outline mt-3">
                @Model.Stats.ActiveUsers hoạt động · @Model.Stats.InactiveUsers tạm khóa
            </p>
        </div>
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-[64px] text-tertiary">description</span>
            </div>
            <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Tài liệu tải lên</p>
            <h3 class="font-headline-lg text-headline-lg font-bold text-on-surface">@FormatNumber(Model.Stats.TotalDocuments)</h3>
            <p class="font-label-md text-label-md text-outline mt-3">
                @Model.Stats.ProcessingDocuments đang xử lý · @Model.Stats.FailedDocuments thất bại
            </p>
        </div>
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-[64px] text-secondary">database</span>
            </div>
            <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Dung lượng</p>
            <h3 class="font-headline-lg text-headline-lg font-bold text-on-surface">@FormatBytes(Model.Stats.TotalStorageUsedBytes)</h3>
            <p class="font-label-md text-label-md text-outline mt-3">@FormatNumber(Model.Stats.TotalDocumentChunks) chunks embedding</p>
        </div>
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-[64px] text-tertiary">chat</span>
            </div>
            <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Phiên chat AI</p>
            <h3 class="font-headline-lg text-headline-lg font-bold text-on-surface">@FormatNumber(Model.Stats.TotalChatSessions)</h3>
            <p class="font-label-md text-label-md text-outline mt-3">@FormatNumber(Model.Stats.TotalChatMessages) tin nhắn · @FormatNumber(Model.Stats.TotalTokensConsumed) tokens</p>
        </div>
    </div>

    <!-- ── Quick stats row ── -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 select-none">
        <div class="bg-gradient-to-br from-primary/10 to-transparent border border-primary/25 rounded-xl p-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-primary/15 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary text-[22px]">person_add</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wide">Người dùng mới (7 ngày)</p>
                <p class="text-xl font-bold text-on-surface">@Model.Stats.NewUsersLast7Days</p>
            </div>
        </div>
        <div class="bg-gradient-to-br from-tertiary/10 to-transparent border border-tertiary/25 rounded-xl p-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-tertiary/15 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-tertiary text-[22px]">chat_bubble</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wide">Chat mới (7 ngày)</p>
                <p class="text-xl font-bold text-on-surface">@Model.Stats.TotalChatSessionsLast7Days</p>
            </div>
        </div>
        <div class="bg-gradient-to-br from-secondary/10 to-transparent border border-secondary/25 rounded-xl p-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-secondary/15 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-secondary text-[22px]">query_stats</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wide">Avg tin nhắn/session</p>
                <p class="text-xl font-bold text-on-surface">@Model.Stats.AvgMessagesPerSession.ToString("0.0")</p>
            </div>
        </div>
        <div class="bg-gradient-to-br from-on-surface-variant/10 to-transparent border border-outline-variant/30 rounded-xl p-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-surface-container-highest flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-surface-variant text-[22px]">upload_file</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wide">Tài liệu mới (7 ngày)</p>
                <p class="text-xl font-bold text-on-surface">@Model.Stats.NewDocumentsLast7Days</p>
            </div>
        </div>
    </div>

    <!-- ── Token usage card ── -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 select-none">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
            <div>
                <h4 class="font-headline-sm text-base font-bold text-on-surface flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px] text-secondary">token</span>
                    Thống kê Token AI
                </h4>
                <p class="text-[11px] text-on-surface-variant mt-0.5">Tổng lượng token đã tiêu thụ qua tất cả phiên chat</p>
            </div>
            <div class="text-right">
                <p class="text-2xl font-bold text-on-surface">@FormatNumber(Model.Stats.TotalTokensConsumed)</p>
                <p class="text-[11px] text-outline">tổng tokens</p>
            </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <div class="flex justify-between items-center mb-1.5">
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-primary block"></span>
                        <span class="text-xs text-on-surface-variant">Prompt tokens (input)</span>
                    </div>
                    <span class="text-xs font-bold text-on-surface">@FormatNumber(Model.Stats.PromptTokensTotal)</span>
                </div>
                <div class="h-2 bg-surface-container-highest rounded-full overflow-hidden">
                    @{
                        var promptPct = Model.Stats.TotalTokensConsumed > 0
                            ? (int)(Model.Stats.PromptTokensTotal * 100 / Model.Stats.TotalTokensConsumed) : 0;
                    }
                    <div class="h-full bg-primary rounded-full transition-all" style="width: @promptPct%"></div>
                </div>
                <p class="text-[10px] text-outline mt-1">@promptPct% tổng tokens</p>
            </div>
            <div>
                <div class="flex justify-between items-center mb-1.5">
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-tertiary block"></span>
                        <span class="text-xs text-on-surface-variant">Completion tokens (output)</span>
                    </div>
                    <span class="text-xs font-bold text-on-surface">@FormatNumber(Model.Stats.CompletionTokensTotal)</span>
                </div>
                <div class="h-2 bg-surface-container-highest rounded-full overflow-hidden">
                    @{
                        var completionPct = Model.Stats.TotalTokensConsumed > 0
                            ? (int)(Model.Stats.CompletionTokensTotal * 100 / Model.Stats.TotalTokensConsumed) : 0;
                    }
                    <div class="h-full bg-tertiary rounded-full transition-all" style="width: @completionPct%"></div>
                </div>
                <p class="text-[10px] text-outline mt-1">@completionPct% tổng tokens</p>
            </div>
        </div>
        <div class="mt-4 pt-4 border-t border-outline-variant/20 flex flex-wrap gap-4 text-[11px] text-on-surface-variant">
            <span>Chat 30 ngày: <strong class="text-on-surface">@FormatNumber(Model.Stats.TotalChatSessionsLast30Days)</strong> sessions</span>
            <span>·</span>
            <span>Chat 7 ngày: <strong class="text-on-surface">@FormatNumber(Model.Stats.TotalChatSessionsLast7Days)</strong> sessions</span>
            <span>·</span>
            <span>Avg: <strong class="text-on-surface">@Model.Stats.AvgMessagesPerSession.ToString("0.0")</strong> tin nhắn/session</span>
        </div>
    </div>

    <!-- ── Charts row 1: Top subjects by docs ── -->
    <div class="grid grid-cols-1 gap-6 select-none">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 flex flex-col">
            <h4 class="font-headline-sm text-base font-bold text-on-surface mb-4">Top môn học theo số tài liệu</h4>
            @if (Model.Stats.TopSubjects.Any())
            {
                <div class="flex-1 min-h-[260px] flex items-center justify-center">
                    <canvas id="topSubjectsChart" class="w-full max-h-[240px]"></canvas>
                </div>
            }
            else
            {
                <div class="flex-1 min-h-[260px] flex items-center justify-center text-center text-on-surface-variant text-xs">
                    <div>
                        <span class="material-symbols-outlined text-[40px] text-outline mb-1 block">menu_book</span>
                        Chưa có môn học nào được tạo.
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ── Charts row 2: 14-day activity + Top by chat ── -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 select-none">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 flex flex-col">
            <h4 class="font-headline-sm text-base font-bold text-on-surface mb-4">Hoạt động 14 ngày gần nhất</h4>
            <div class="flex-1 min-h-[240px]">
                <canvas id="activityChart" class="w-full h-full max-h-[220px]"></canvas>
            </div>
        </div>

        <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 flex flex-col">
            <h4 class="font-headline-sm text-base font-bold text-on-surface mb-4">Top môn học được hỏi nhiều nhất</h4>
            @if (Model.Stats.TopSubjectsByChat.Any())
            {
                <div class="flex-1 min-h-[240px] flex items-center justify-center">
                    <canvas id="topSubjectsChatChart" class="w-full max-h-[220px]"></canvas>
                </div>
            }
            else
            {
                <div class="flex-1 min-h-[240px] flex items-center justify-center text-center text-on-surface-variant text-xs">
                    <div>
                        <span class="material-symbols-outlined text-[36px] text-outline block mb-2">chat_bubble</span>
                        Chưa có phiên chat nào.
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ── Top subjects list ── -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5">
        <h4 class="font-headline-sm text-base font-bold text-on-surface mb-3 select-none">Top môn học theo tài liệu</h4>
        @if (Model.Stats.TopSubjects.Any())
        {
            <ul class="space-y-2">
                @foreach (var subject in Model.Stats.TopSubjects)
                {
                    <li class="flex items-center justify-between bg-surface-container border border-outline-variant/20 rounded-lg px-3 py-2">
                        <div class="min-w-0">
                            <p class="text-xs font-mono text-primary font-bold">@subject.SubjectCode</p>
                            <p class="text-sm font-semibold text-on-surface truncate">@subject.Name</p>
                        </div>
                        <div class="text-right text-[11px] text-on-surface-variant shrink-0 ml-4">
                            <span class="font-bold text-on-surface">@subject.DocumentCount</span> tài liệu
                            <br />
                            <span class="text-tertiary font-bold">@FormatBytes(subject.StorageBytes)</span>
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="text-center py-8 text-on-surface-variant text-xs">Chưa có dữ liệu.</div>
        }
    </div>

    <!-- ── Per-subject detailed stats table ── -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5">
        <div class="flex items-center justify-between mb-4 select-none">
            <div>
                <h4 class="font-headline-sm text-base font-bold text-on-surface flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px] text-primary">analytics</span>
                    Thống kê chi tiết theo môn học
                </h4>
                <p class="text-[11px] text-on-surface-variant mt-0.5">Tổng hợp tài liệu, phiên chat, tin nhắn và token tiêu thụ</p>
            </div>
            <span class="text-[11px] text-outline font-mono">@Model.Stats.SubjectDetailStats.Count môn</span>
        </div>
        @if (Model.Stats.SubjectDetailStats.Any())
        {
            <div class="overflow-x-auto rounded-lg border border-outline-variant/20">
                <table class="w-full text-xs">
                    <thead>
                        <tr class="bg-surface-container border-b border-outline-variant/20 select-none">
                            <th class="text-left px-3 py-2.5 font-bold text-on-surface-variant uppercase tracking-wide text-[10px]">Môn học</th>
                            <th class="text-center px-3 py-2.5 font-bold text-on-surface-variant uppercase tracking-wide text-[10px]">Tài liệu</th>
                            <th class="text-center px-3 py-2.5 font-bold text-on-surface-variant uppercase tracking-wide text-[10px]">Sessions</th>
                            <th class="text-center px-3 py-2.5 font-bold text-on-surface-variant uppercase tracking-wide text-[10px]">Tin nhắn</th>
                            <th class="text-center px-3 py-2.5 font-bold text-on-surface-variant uppercase tracking-wide text-[10px]">Tokens</th>
                            <th class="text-right px-3 py-2.5 font-bold text-on-surface-variant uppercase tracking-wide text-[10px]">Dung lượng</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/10">
                        @foreach (var s in Model.Stats.SubjectDetailStats)
                        {
                            <tr class="hover:bg-surface-container/50 transition-colors">
                                <td class="px-3 py-2.5">
                                    <span class="text-[10px] font-mono text-primary font-bold block">@s.SubjectCode</span>
                                    <span class="text-on-surface font-semibold">@s.Name</span>
                                </td>
                                <td class="px-3 py-2.5 text-center">
                                    <span class="font-bold text-on-surface">@s.DocumentCount</span>
                                </td>
                                <td class="px-3 py-2.5 text-center">
                                    @if (s.ChatSessionCount > 0)
                                    {
                                        <span class="inline-flex items-center gap-0.5 bg-tertiary/10 text-tertiary font-bold px-1.5 py-0.5 rounded">@s.ChatSessionCount</span>
                                    }
                                    else
                                    {
                                        <span class="text-outline">0</span>
                                    }
                                </td>
                                <td class="px-3 py-2.5 text-center text-on-surface-variant">@FormatNumber(s.ChatMessageCount)</td>
                                <td class="px-3 py-2.5 text-center">
                                    @if (s.TokensConsumed > 0)
                                    {
                                        <span class="text-secondary font-bold">@FormatNumber(s.TokensConsumed)</span>
                                    }
                                    else
                                    {
                                        <span class="text-outline">—</span>
                                    }
                                </td>
                                <td class="px-3 py-2.5 text-right text-on-surface-variant">@FormatBytes(s.StorageBytes)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-8 text-on-surface-variant text-xs">Chưa có dữ liệu môn học.</div>
        }
    </div>

    <!-- ── Quick actions ── -->
    <div class="space-y-4">
        <h3 class="font-headline-sm text-headline-sm font-bold text-on-surface select-none">Hành động nhanh</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 flex flex-col justify-between">
                <div>
                    <h4 class="font-headline-sm text-base font-bold text-on-surface mb-2">Quản lý người dùng</h4>
                    <p class="font-body-md text-xs text-on-surface-variant leading-relaxed mb-4">Tạo mới, đổi mật khẩu, chỉnh sửa, xóa tài khoản người dùng hoặc tải danh sách hàng loạt từ file Excel.</p>
                </div>
                <div class="flex gap-2 flex-wrap">
                    <a asp-page="/Admin/Users" class="bg-primary text-on-primary font-label-md text-xs px-4 py-2 rounded-lg hover:bg-primary-fixed hover:text-on-primary-fixed transition-colors font-semibold shadow-sm">
                        Mở trang quản lý →
                    </a>
                </div>
            </div>
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 flex flex-col justify-between">
                <div>
                    <h4 class="font-headline-sm text-base font-bold text-on-surface mb-2">Quản lý môn học</h4>
                    <p class="font-body-md text-xs text-on-surface-variant leading-relaxed mb-4">Đăng ký môn học mới, thiết lập giảng viên phụ trách và cấu hình các học liệu giảng dạy.</p>
                </div>
                <a asp-page="/Subject/Index" class="bg-primary text-on-primary font-label-md text-xs px-4 py-2 rounded-lg hover:bg-primary-fixed hover:text-on-primary-fixed transition-colors font-semibold shadow-sm self-start">
                    Quản lý môn học →
                </a>
            </div>
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 flex flex-col justify-between">
                <div>
                    <h4 class="font-headline-sm text-base font-bold text-on-surface mb-2">Quản lý tài liệu</h4>
                    <p class="font-body-md text-xs text-on-surface-variant leading-relaxed mb-4">Theo dõi trạng thái xử lý, thử lại khi thất bại, xóa tài liệu lỗi.</p>
                </div>
                <a asp-page="/Admin/Documents" class="bg-primary text-on-primary font-label-md text-xs px-4 py-2 rounded-lg hover:bg-primary-fixed hover:text-on-primary-fixed transition-colors font-semibold shadow-sm self-start">
                    Mở danh sách →
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const font = { family: 'system-ui', size: 11 };
            const tickColor = '#c1c6d6';
            const gridColor = 'rgba(65,71,84,0.3)';



            // 2) Top subjects bar (by documents)
            const subjectEl = document.getElementById('topSubjectsChart');
            if (subjectEl) {
                const subLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.TopSubjects.Select(s => s.SubjectCode)));
                const docs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.TopSubjects.Select(s => s.DocumentCount)));
                new Chart(subjectEl.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: subLabels,
                        datasets: [{ label: 'Tài liệu', data: docs, backgroundColor: 'rgba(173,199,255,0.85)', borderColor: '#adc7ff', borderWidth: 1, borderRadius: 6 }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom', labels: { color: tickColor, font } } },
                        scales: {
                            y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: tickColor, font, precision: 0 } },
                            x: { grid: { display: false }, ticks: { color: tickColor, font, maxRotation: 30 } }
                        }
                    }
                });
            }

            // 3) 14-day activity line (users + docs + chat sessions)
            const actLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.Last14DaysActivity.Select(d => d.Day.ToString("MM/dd"))));
            const newUsers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.Last14DaysActivity.Select(d => d.NewUsers)));
            const newDocs  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.Last14DaysActivity.Select(d => d.NewDocuments)));
            const newChats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.Last14DaysActivity.Select(d => d.NewChatSessions)));
            new Chart(document.getElementById('activityChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: actLabels,
                    datasets: [
                        {
                            label: 'Người dùng mới',
                            data: newUsers,
                            borderColor: '#adc7ff', backgroundColor: 'rgba(173,199,255,0.12)',
                            fill: true, tension: 0.35, borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#adc7ff'
                        },
                        {
                            label: 'Tài liệu mới',
                            data: newDocs,
                            borderColor: '#6ddd81', backgroundColor: 'rgba(109,221,129,0.08)',
                            fill: true, tension: 0.35, borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#6ddd81'
                        },
                        {
                            label: 'Chat mới',
                            data: newChats,
                            borderColor: '#ffb4ab', backgroundColor: 'rgba(255,180,171,0.08)',
                            fill: true, tension: 0.35, borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#ffb4ab'
                        }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { color: tickColor, font } } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: tickColor, font, precision: 0 } },
                        x: { grid: { display: false }, ticks: { color: tickColor, font } }
                    }
                }
            });

            // 4) Top subjects by chat (horizontal bar)
            const chatChartEl = document.getElementById('topSubjectsChatChart');
            if (chatChartEl) {
                const chatLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.TopSubjectsByChat.Select(s => s.SubjectCode)));
                const chatCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.TopSubjectsByChat.Select(s => s.ChatCount)));
                new Chart(chatChartEl.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: chatLabels,
                        datasets: [{
                            label: 'Lượt chat',
                            data: chatCounts,
                            backgroundColor: 'rgba(255,180,171,0.85)',
                            borderColor: '#ffb4ab',
                            borderWidth: 1,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: tickColor, font, precision: 0 } },
                            y: { grid: { display: false }, ticks: { color: tickColor, font } }
                        }
                    }
                });
            }
        });
    </script>
}
