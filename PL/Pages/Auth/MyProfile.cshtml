@page
@model PL.Pages.Auth.MyProfileModel
@using Core.Entities
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var roleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Student";
    Enum.TryParse<UserRole>(roleClaim, out var userRole);
    string backUrl = userRole == UserRole.Admin ? "/Admin/Index" :
                     userRole == UserRole.Lecturer ? "/Subject/MySubjects" :
                     "/Subject/Browse";
}

<div class="max-w-6xl mx-auto space-y-6 py-4 animate-fade-in select-none">
    <!-- Back Navigation and Breadcrumbs -->
    <div class="flex items-center justify-between px-1">
        <div class="flex items-center gap-3">
            <a href="@backUrl" class="inline-flex items-center gap-1.5 text-on-surface-variant hover:text-primary text-xs font-bold transition-all hover:-translate-x-0.5 duration-200">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                Quay lại
            </a>
            <span class="text-outline-variant/50">/</span>
            <span class="text-xs text-outline font-medium">Hồ sơ cá nhân</span>
        </div>
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">
        
        <!-- LEFT COLUMN: Profile Overview (2/5 cols) -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Profile Card -->
            <div class="relative bg-surface-container-low border border-outline-variant/30 rounded-3xl p-6 shadow-xl overflow-hidden group">
                <div class="absolute -right-16 -top-16 w-36 h-36 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all duration-300"></div>
                <div class="absolute -left-16 -bottom-16 w-36 h-36 bg-secondary/5 rounded-full blur-2xl"></div>

                <div class="relative flex flex-col items-center text-center">
                    <!-- Profile Avatar with animated gradient border -->
                    <div class="relative p-1 rounded-3xl bg-gradient-to-tr from-primary via-secondary to-tertiary shadow-lg group-hover:scale-105 transition-transform duration-300">
                        <div class="w-20 h-20 rounded-[22px] bg-surface-container-high text-primary font-extrabold text-3xl flex items-center justify-center select-none font-serif">
                            @(string.IsNullOrEmpty(User.Identity?.Name) ? "U" : User.Identity!.Name.Substring(0, 1).ToUpper())
                        </div>
                    </div>

                    <h2 class="text-lg font-extrabold text-on-surface mt-4 tracking-tight">@User.Identity?.Name</h2>
                    <p class="text-xs font-mono text-outline mt-1 truncate max-w-full">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                    
                    <span class="mt-3 px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-[10px] font-bold uppercase tracking-wider border border-secondary/20 shadow-sm">
                        @roleClaim
                    </span>
                </div>

                <!-- Account Metrics or Info cards -->
                <div class="mt-8 space-y-3 pt-6 border-t border-outline-variant/30">
                    <div class="flex items-center justify-between p-3 rounded-2xl bg-surface/40 border border-outline-variant/20 hover:bg-surface/60 transition-colors">
                        <div class="flex items-center gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[18px]">badge</span>
                            <span class="text-xs text-on-surface-variant font-semibold">Họ và tên</span>
                        </div>
                        <span class="text-xs text-on-surface font-bold">@User.Identity?.Name</span>
                    </div>

                    <div class="flex items-center justify-between p-3 rounded-2xl bg-surface/40 border border-outline-variant/20 hover:bg-surface/60 transition-colors">
                        <div class="flex items-center gap-2.5">
                            <span class="material-symbols-outlined text-secondary text-[18px]">key</span>
                            <span class="text-xs text-on-surface-variant font-semibold">Mã định danh</span>
                        </div>
                        <span class="text-xs text-on-surface font-mono font-bold">@Model.UserCode</span>
                    </div>

                    <div class="flex items-center justify-between p-3 rounded-2xl bg-surface/40 border border-outline-variant/20 hover:bg-surface/60 transition-colors">
                        <div class="flex items-center gap-2.5">
                            <span class="material-symbols-outlined text-tertiary text-[18px]">verified_user</span>
                            <span class="text-xs text-on-surface-variant font-semibold">Trạng thái</span>
                        </div>
                        <span class="inline-flex items-center gap-1 text-[11px] text-tertiary font-bold">
                            <span class="w-1.5 h-1.5 bg-tertiary rounded-full animate-ping"></span>
                            Hoạt động
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Change Password (3/5 cols) -->
        <div class="lg:col-span-3">
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden">
                <div class="absolute -right-20 -bottom-20 w-44 h-44 bg-tertiary/5 rounded-full blur-3xl"></div>

                <div class="flex items-center gap-3 mb-6 pb-4 border-b border-outline-variant/20">
                    <div class="w-10 h-10 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-[22px] filled">lock_reset</span>
                    </div>
                    <div>
                        <h2 class="text-base font-bold text-on-surface">Đổi mật khẩu</h2>
                        <p class="text-[11px] text-on-surface-variant mt-0.5 font-medium">Bảo vệ tài khoản của bạn bằng cách sử dụng mật khẩu mạnh</p>
                    </div>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-error-container/10 border border-error-container/30 text-error p-4 rounded-2xl text-xs flex items-start gap-2.5 mb-6 animate-shake">
                        <span class="material-symbols-outlined text-[18px] shrink-0">error</span>
                        <div asp-validation-summary="ModelOnly" class="font-medium leading-relaxed"></div>
                    </div>
                }

                <form method="post" asp-page-handler="ChangePassword" class="space-y-5">
                    <!-- Current Password -->
                    <div class="space-y-1.5">
                        <label class="block text-[11px] font-bold text-on-surface-variant uppercase tracking-wider">Mật khẩu hiện tại</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-3 top-3 text-outline text-[18px] group-focus-within:text-primary transition-colors">vpn_key</span>
                            <input type="password" name="currentPassword" id="currentPassword" 
                                   class="bg-surface-container-high border-2 border-outline-variant/40 rounded-xl pl-10 pr-12 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-xs font-bold shadow-inner" 
                                   placeholder="Nhập mật khẩu hiện tại" required />
                            <button type="button" onclick="togglePasswordVisibility('currentPassword', 'currentPasswordEye')" class="absolute right-3 top-2.5 p-1 text-outline hover:text-on-surface transition-colors">
                                <span class="material-symbols-outlined text-[18px]" id="currentPasswordEye">visibility</span>
                            </button>
                        </div>
                    </div>

                    <!-- New Password -->
                    <div class="space-y-1.5">
                        <label class="block text-[11px] font-bold text-on-surface-variant uppercase tracking-wider">Mật khẩu mới</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-3 top-3 text-outline text-[18px] group-focus-within:text-primary transition-colors">lock</span>
                            <input type="password" name="newPassword" id="newPassword" 
                                   class="bg-surface-container-high border-2 border-outline-variant/40 rounded-xl pl-10 pr-12 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-xs font-bold shadow-inner" 
                                   placeholder="Tối thiểu 6 ký tự" minlength="6" required />
                            <button type="button" onclick="togglePasswordVisibility('newPassword', 'newPasswordEye')" class="absolute right-3 top-2.5 p-1 text-outline hover:text-on-surface transition-colors">
                                <span class="material-symbols-outlined text-[18px]" id="newPasswordEye">visibility</span>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="space-y-1.5">
                        <label class="block text-[11px] font-bold text-on-surface-variant uppercase tracking-wider">Xác nhận mật khẩu mới</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-3 top-3 text-outline text-[18px] group-focus-within:text-primary transition-colors">lock</span>
                            <input type="password" name="confirmPassword" id="confirmPassword" 
                                   class="bg-surface-container-high border-2 border-outline-variant/40 rounded-xl pl-10 pr-12 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-xs font-bold shadow-inner" 
                                   placeholder="Nhập lại mật khẩu mới" minlength="6" required />
                            <button type="button" onclick="togglePasswordVisibility('confirmPassword', 'confirmPasswordEye')" class="absolute right-3 top-2.5 p-1 text-outline hover:text-on-surface transition-colors">
                                <span class="material-symbols-outlined text-[18px]" id="confirmPasswordEye">visibility</span>
                            </button>
                        </div>
                        <p id="matchHint" class="text-[10px] font-semibold mt-1.5 hidden flex items-center gap-1"></p>
                    </div>

                    <!-- Actions -->
                    <div class="flex flex-col sm:flex-row gap-3 pt-3">
                        <a href="@backUrl" 
                           class="flex-1 h-12 flex items-center justify-center text-xs font-bold text-on-surface-variant border-2 border-outline-variant/40 hover:border-outline-variant rounded-xl transition-all hover:bg-surface/20 duration-200">
                            Hủy bỏ
                        </a>
                        <button type="submit" 
                                class="flex-1 h-12 bg-primary hover:bg-primary/90 text-on-primary font-bold rounded-xl shadow-lg hover:shadow-primary/20 hover:scale-[1.01] active:scale-[0.99] flex items-center justify-center gap-2 duration-200 cursor-pointer text-xs whitespace-nowrap">
                            <span class="material-symbols-outlined text-[18px] font-bold">save</span>
                            <span>Cập nhật mật khẩu</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const np = document.getElementById('newPassword');
        const cp = document.getElementById('confirmPassword');
        const hint = document.getElementById('matchHint');

        function checkMatch() {
            if (!cp.value) { 
                hint.classList.add('hidden'); 
                return; 
            }
            if (np.value === cp.value) {
                hint.innerHTML = `<span class="material-symbols-outlined text-[14px] text-tertiary filled">check_circle</span> Mật khẩu hoàn toàn trùng khớp`;
                hint.className = 'text-[10px] font-bold mt-1.5 text-tertiary flex items-center gap-1';
            } else {
                hint.innerHTML = `<span class="material-symbols-outlined text-[14px] text-error filled">cancel</span> Mật khẩu chưa trùng khớp`;
                hint.className = 'text-[10px] font-bold mt-1.5 text-error flex items-center gap-1';
            }
            hint.classList.remove('hidden');
        }
        
        np.addEventListener('input', checkMatch);
        cp.addEventListener('input', checkMatch);

        function togglePasswordVisibility(inputId, eyeId) {
            const input = document.getElementById(inputId);
            const eye = document.getElementById(eyeId);
            if (input && eye) {
                if (input.type === 'password') {
                    input.type = 'text';
                    eye.textContent = 'visibility_off';
                    eye.classList.add('text-primary');
                } else {
                    input.type = 'password';
                    eye.textContent = 'visibility';
                    eye.classList.remove('text-primary');
                }
            }
        }
    </script>
}
