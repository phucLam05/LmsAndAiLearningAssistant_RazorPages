@page
@model PL.Pages.Auth.ChangePasswordModel
@{
    ViewData["Title"] = "Kích hoạt tài khoản";
}

<div class="bg-surface-container-high/60 backdrop-blur-md border border-outline-variant/40 rounded-2xl p-6 shadow-2xl relative overflow-hidden">
    <div class="mb-6">
        <h3 class="text-headline-md font-bold text-on-surface" style="font-size: 24px;">Kích hoạt tài khoản</h3>
        <p class="text-body-md text-outline mt-1">Đăng nhập lần đầu: Vui lòng đổi mật khẩu mới để bảo mật và kích hoạt tài khoản của bạn.</p>
    </div>

    <form method="post" class="space-y-4">
        <input type="hidden" asp-for="Input.UserId" />
        <input type="hidden" asp-for="Email" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="bg-error-container/20 border border-error-container/40 text-error p-3 rounded-xl text-body-md flex items-start gap-2">
                <span class="material-symbols-outlined text-[20px]">error</span>
                <span>Thông tin nhập vào chưa đúng hoặc mật khẩu tạm thời không chính xác.</span>
            </div>
        }

        <div class="space-y-1">
            <label class="block text-label-md font-bold text-on-surface-variant">Địa chỉ Email</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">mail</span>
                <input type="text" class="bg-surface-container-low/50 border border-outline-variant/30 rounded-xl pl-10 pr-4 py-3 text-outline focus:outline-none w-full text-body-md" value="@Model.Email" disabled />
            </div>
        </div>

        <div class="space-y-1">
            <label asp-for="Input.TemporaryPassword" class="block text-label-md font-bold text-on-surface-variant">Mật khẩu tạm thời</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">vpn_key</span>
                <input asp-for="Input.TemporaryPassword" type="password" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-body-md" placeholder="Nhập mật khẩu tạm nhận được" required />
            </div>
            <span asp-validation-for="Input.TemporaryPassword" class="text-error text-label-md block mt-1"></span>
        </div>

        <div class="space-y-1">
            <label asp-for="Input.NewPassword" class="block text-label-md font-bold text-on-surface-variant">Mật khẩu mới</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">lock</span>
                <input asp-for="Input.NewPassword" type="password" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-body-md" placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" required />
            </div>
            <span asp-validation-for="Input.NewPassword" class="text-error text-label-md block mt-1"></span>
        </div>

        <div class="space-y-1">
            <label asp-for="Input.ConfirmPassword" class="block text-label-md font-bold text-on-surface-variant">Xác nhận mật khẩu mới</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">lock</span>
                <input asp-for="Input.ConfirmPassword" type="password" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-body-md" placeholder="Xác nhận lại mật khẩu mới" required />
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-error text-label-md block mt-1"></span>
        </div>

        <button type="submit" class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-3 px-4 rounded-xl shadow-lg transition-all duration-200 flex items-center justify-center gap-2 hover:scale-[1.01] mt-6">
            <span>Kích hoạt & Đăng nhập</span>
            <span class="material-symbols-outlined text-[18px]">verified</span>
        </button>
    </form>

    <div class="border-t border-outline-variant/30 mt-6 pt-6 text-center text-body-md text-outline">
        <a asp-page="/Auth/Login" class="text-primary hover:underline font-semibold flex items-center justify-center gap-1">
            <span class="material-symbols-outlined text-[16px]">arrow_back</span> Quay lại đăng nhập
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
