@page
@model PL.Pages.Auth.ForceChangePasswordModel
@{
    ViewData["Title"] = "Kích hoạt tài khoản";
}

<div class="bg-surface-container-high/60 backdrop-blur-md border border-outline-variant/40 rounded-2xl p-6 shadow-2xl relative overflow-hidden animate-fade-in">
    <div class="flex flex-col items-center text-center mb-6">
        <div class="w-14 h-14 bg-amber-500/15 border border-amber-500/35 rounded-full flex items-center justify-center mb-3">
            <span class="material-symbols-outlined text-[28px] text-amber-400">shield_lock</span>
        </div>
        <h3 class="text-headline-md font-bold text-on-surface" style="font-size: 20px;">Kích hoạt tài khoản</h3>
        <p class="text-xs text-outline mt-1 max-w-[280px]">Đây là lần đăng nhập đầu tiên. Vui lòng cập nhật mật khẩu tạm thời để kích hoạt và bảo mật tài khoản của bạn.</p>
        @if (!string.IsNullOrEmpty(Model.CurrentEmail))
        {
            <div class="mt-3 bg-surface-container-low border border-outline-variant/30 rounded-lg px-3 py-1.5 text-xs font-mono text-on-surface-variant">
                @Model.CurrentEmail
            </div>
        }
    </div>

    <div asp-validation-summary="ModelOnly" class="bg-error-container/20 border border-error-container/40 text-error p-3 rounded-xl text-xs flex items-start gap-2 mb-4">
        <span class="material-symbols-outlined text-[18px]">error</span>
        <span>Cập nhật mật khẩu thất bại. Vui lòng kiểm tra lại thông tin.</span>
    </div>

    <form method="post" id="forceChangeForm" class="space-y-4">
        <div class="space-y-1">
            <label for="currentPassword" class="block text-label-md font-bold text-on-surface-variant">Mật khẩu tạm thời</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">vpn_key</span>
                <input type="password" id="currentPassword" name="currentPassword" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-xs" placeholder="Nhập mật khẩu tạm trong email" autocomplete="current-password" required />
            </div>
            <p class="text-[10px] text-outline mt-1">Mật khẩu tạm đã được gửi qua email khi Admin tạo tài khoản cho bạn.</p>
        </div>

        <div class="space-y-1">
            <label for="newPassword" class="block text-label-md font-bold text-on-surface-variant">Mật khẩu mới</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">lock</span>
                <input type="password" id="newPassword" name="newPassword" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-xs" placeholder="••••••••" autocomplete="new-password" required />
            </div>
            <div class="w-full h-1 bg-surface-container-low rounded-full overflow-hidden mt-2">
                <div class="h-full bg-red-500 transition-all duration-300" id="strengthProgress" style="width: 0%"></div>
            </div>
            <span id="strengthText" class="text-outline text-[10px] block mt-1">Mật khẩu tối thiểu 6 ký tự.</span>
        </div>

        <div class="space-y-1">
            <label for="confirmPassword" class="block text-label-md font-bold text-on-surface-variant">Xác nhận mật khẩu mới</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">lock</span>
                <input type="password" id="confirmPassword" name="confirmPassword" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-xs" placeholder="••••••••" autocomplete="new-password" required />
            </div>
            <span id="matchText" class="text-error text-[10px] block mt-1"></span>
        </div>

        <button type="submit" id="submitBtn" class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-3.5 px-4 rounded-xl shadow-lg transition-all duration-200 flex items-center justify-center gap-2 hover:scale-[1.01] mt-6 disabled:opacity-40 disabled:hover:scale-100 disabled:cursor-not-allowed" disabled>
            <span>Cập nhật mật khẩu & Kích hoạt</span>
            <span class="material-symbols-outlined text-[18px]">verified_user</span>
        </button>
    </form>
</div>

@section Scripts {
    <script>
        const newPassword = document.getElementById('newPassword');
        const confirmPassword = document.getElementById('confirmPassword');
        const strengthProgress = document.getElementById('strengthProgress');
        const strengthText = document.getElementById('strengthText');
        const matchText = document.getElementById('matchText');
        const submitBtn = document.getElementById('submitBtn');

        newPassword.addEventListener('input', validatePassword);
        confirmPassword.addEventListener('input', validatePassword);

        function validatePassword() {
            const val = newPassword.value;
            let score = 0;
            if (val.length >= 6) score += 1;
            if (/[a-z]/.test(val) && /[A-Z]/.test(val)) score += 1;
            if (/\d/.test(val)) score += 1;
            if (/[^A-Za-z0-9]/.test(val)) score += 1;
            let progressColor = '#dc2626';
            let label = 'Yếu';
            let width = '25%';
            if (val.length < 6) { progressColor = '#dc2626'; label = 'Quá ngắn (tối thiểu 6 ký tự)'; width = '10%'; }
            else if (score === 1) { progressColor = '#ea580c'; label = 'Yếu'; width = '25%'; }
            else if (score === 2) { progressColor = '#ca8a04'; label = 'Trung bình'; width = '50%'; }
            else if (score === 3) { progressColor = '#2563eb'; label = 'Tốt'; width = '75%'; }
            else if (score >= 4) { progressColor = '#16a34a'; label = 'Mạnh'; width = '100%'; }
            strengthProgress.style.width = width;
            strengthProgress.style.backgroundColor = progressColor;
            strengthText.textContent = val ? `Độ mạnh: ${label}` : 'Mật khẩu tối thiểu 6 ký tự.';
            strengthText.style.color = progressColor;
            const passwordsMatch = val && val === confirmPassword.value;
            if (confirmPassword.value) {
                if (passwordsMatch) { matchText.textContent = 'Mật khẩu trùng khớp'; matchText.className = 'text-tertiary text-[10px] block mt-1'; }
                else { matchText.textContent = 'Mật khẩu không trùng khớp'; matchText.className = 'text-error text-[10px] block mt-1'; }
            } else { matchText.textContent = ''; }
            submitBtn.disabled = !(val.length >= 6 && passwordsMatch);
        }
    </script>
}
