@page
@model PL.Pages.Auth.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="bg-surface-container-high/60 backdrop-blur-md border border-outline-variant/40 rounded-2xl p-6 shadow-2xl relative overflow-hidden w-full max-w-md">
    <div class="mb-6">
        <h3 class="text-headline-md font-bold text-on-surface" style="font-size: 24px;">Quên mật khẩu</h3>
        <p class="text-body-md text-outline mt-1">
            Nhập địa chỉ email của bạn để nhận mật khẩu tạm thời mới.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-gradient-to-br from-tertiary/10 to-transparent border border-tertiary/30 text-tertiary p-4 rounded-xl text-body-md mb-6 leading-relaxed flex items-start gap-2">
            <span class="material-symbols-outlined text-[20px] shrink-0 mt-0.5">check_circle</span>
            <span>@Model.SuccessMessage</span>
        </div>
        
        <div class="mt-6 select-none">
            <a asp-page="/Auth/Login" class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-3 px-4 rounded-xl shadow-lg transition-all duration-200 flex items-center justify-center gap-2 hover:scale-[1.01]">
                <span>Quay lại Đăng nhập</span>
                <span class="material-symbols-outlined text-[18px]">login</span>
            </a>
        </div>
    }
    else
    {
        <form method="post" class="space-y-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-error-container/20 border border-error-container/40 text-error p-3 rounded-xl text-body-md flex items-start gap-2">
                    <span class="material-symbols-outlined text-[20px] shrink-0">error</span>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <div class="space-y-1">
                <label asp-for="Email" class="block text-label-md font-bold text-on-surface-variant">
                    Địa chỉ Email
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">mail</span>
                    <input asp-for="Email"
                           autocomplete="email"
                           class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-body-md"
                           placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-error text-label-md block mt-1"></span>
            </div>

            <button type="submit"
                    class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-3 px-4 rounded-xl shadow-lg transition-all duration-200 flex items-center justify-center gap-2 hover:scale-[1.01] mt-6">
                <span>Gửi yêu cầu</span>
                <span class="material-symbols-outlined text-[18px]">send</span>
            </button>
            
            <div class="flex justify-center select-none mt-4">
                <a asp-page="/Auth/Login" class="text-label-md font-semibold text-primary hover:text-primary-fixed transition-colors flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">arrow_back</span> Quay lại Đăng nhập
                </a>
            </div>
        </form>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
